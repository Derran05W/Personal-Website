# Pin the project runtime to Node 22 LTS (engines: >=22 <23, .nvmrc: 22). pnpm downloads
# this version itself and uses it for all `pnpm run`/`pnpm dev`/`pnpm test` invocations,
# so a newer system Node (e.g. Node 25, whose experimental localStorage global shadows
# jsdom's and breaks every persistence test) can never leak into scripts.
use-node-version=22.23.1
